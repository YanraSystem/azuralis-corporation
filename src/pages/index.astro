---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import TradingChart from '../components/TradingChart.astro'
import MarketTicker from '../components/MarketTicker.astro'
import Marquee from '../components/Marquee.astro'
import Footer from '../components/Footer.astro'
---

<Layout title="Accueil">
  <Navbar />

  <!-- ══════════════════════════════════════════════
       HERO — Split layout: text left, chart right
  ══════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- HUD grid -->
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(255,255,255,0.15) 59px, rgba(255,255,255,0.15) 60px), repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(255,255,255,0.15) 59px, rgba(255,255,255,0.15) 60px);"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_50%,rgba(59,130,246,0.06),transparent_60%)]"></div>

    <!-- Logo watermark -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[clamp(500px,70vw,900px)] pointer-events-none select-none">
      <img src="/images/azuralis-logo.png" alt="" class="w-full invert opacity-[0.03]" />
    </div>

    <div class="relative z-10 w-full px-[clamp(24px,5vw,80px)] py-32 md:py-0">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-8 items-center">
        <!-- Left — text -->
        <div>
          <div class="mb-6" data-reveal>
            <span class="font-mono text-[10px] tracking-[0.15em] uppercase text-[var(--color-accent)]">
              AZURALIS CORPORATION
            </span>
          </div>

          <h1 class="font-display font-300 tracking-[-0.04em] leading-[0.9] mb-8" data-reveal>
            <span class="block text-[clamp(2.8rem,7vw,6.5rem)] text-[var(--color-text)]">
              Master the Lead.
            </span>
            <span class="block text-[clamp(2.8rem,7vw,6.5rem)] text-[var(--color-text)] italic">
              Own the Markets.
            </span>
          </h1>

          <p class="text-[15px] font-300 text-[var(--color-text-muted)] max-w-md leading-[1.7] mb-10" data-reveal>
            Trading Forex & Matieres Premieres. Une approche institutionnelle fondee sur la discipline, la transparence et la gestion du risque.
          </p>

          <!-- Stats row -->
          <div class="flex gap-10 mb-10 pt-8 border-t border-[var(--color-border)]" data-reveal-stagger>
            <div>
              <p class="font-display text-[clamp(1.8rem,3vw,2.5rem)] font-300 text-[var(--color-text)]">FX</p>
              <p class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-text-subtle)] mt-1">Forex</p>
            </div>
            <div>
              <p class="font-display text-[clamp(1.8rem,3vw,2.5rem)] font-300 text-[var(--color-text)]">CMDTY</p>
              <p class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-text-subtle)] mt-1">Commodites</p>
            </div>
            <div>
              <p class="font-display text-[clamp(1.8rem,3vw,2.5rem)] font-300 text-green-400">+</p>
              <p class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-text-subtle)] mt-1">Rigueur</p>
            </div>
          </div>

          <a href="/a-propos" class="group inline-flex items-center gap-3 border border-[var(--color-border)] px-6 py-3 text-[11px] tracking-[0.12em] uppercase text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 transition-all duration-400" data-reveal>
            Decouvrir AZURALIS
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform duration-400 group-hover:translate-x-1">
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Right — Trading chart -->
        <div class="hidden lg:block" data-reveal-right>
          <TradingChart />
        </div>
      </div>
    </div>

    <!-- Scroll line -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center">
      <span class="font-mono text-[8px] tracking-[0.2em] uppercase text-[var(--color-text-subtle)] mb-2">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-[var(--color-text-subtle)] to-transparent"></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       MARKET TICKER
  ══════════════════════════════════════════════ -->
  <MarketTicker />

  <!-- ══════════════════════════════════════════════
       01 — MARCHES — Rich visual cards
  ══════════════════════════════════════════════ -->
  <section class="py-[clamp(5rem,12vh,10rem)]">
    <div class="px-[clamp(24px,5vw,80px)]">
      <div class="flex items-center gap-4 mb-16" data-reveal>
        <span class="section-num">01</span>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
        <span class="font-mono text-[11px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Nos marches</span>
      </div>

      <!-- Asymmetric cards with visual elements -->
      <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-6">
        <!-- Forex — large card -->
        <div class="group relative border border-[var(--color-border)] overflow-hidden hover:border-[var(--color-accent)]/20 transition-all duration-500" data-reveal-left>
          <!-- Chart background -->
          <div class="absolute inset-0 opacity-[0.04]">
            <svg viewBox="0 0 400 200" fill="none" class="w-full h-full">
              <path d="M0 150 Q50 130, 100 140 T200 100 T300 80 T400 50" stroke="#3b82f6" stroke-width="1.5"/>
              <path d="M0 150 Q50 130, 100 140 T200 100 T300 80 T400 50 V200 H0Z" fill="url(#fadeBlue)"/>
              <defs><linearGradient id="fadeBlue" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3"/><stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/></linearGradient></defs>
            </svg>
          </div>

          <div class="relative p-[clamp(2rem,4vw,3.5rem)]">
            <div class="flex items-center justify-between mb-8">
              <span class="font-mono text-[10px] tracking-[0.15em] uppercase text-[var(--color-accent)]">Foreign Exchange</span>
              <span class="font-mono text-[10px] tracking-[0.1em] text-green-400 opacity-70">LIVE</span>
            </div>

            <h3 class="font-display text-[clamp(2.5rem,5vw,4rem)] font-300 tracking-[-0.03em] text-[var(--color-text)] mb-6 leading-[1]">
              Forex
            </h3>

            <p class="text-[15px] font-300 text-[var(--color-text-muted)] leading-[1.7] mb-10 max-w-lg">
              Le marche des changes est le plus liquide au monde — plus de 6 000 milliards de dollars echanges quotidiennement. Nous operons sur les paires majeures avec une gestion du risque stricte.
            </p>

            <!-- Data grid -->
            <div class="grid grid-cols-4 gap-6 pt-6 border-t border-[var(--color-border)]">
              <div>
                <p class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Volume/jour</p>
                <p class="font-mono text-[18px] text-[var(--color-text)] mt-2 font-500">6.6T$</p>
              </div>
              <div>
                <p class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Horaires</p>
                <p class="font-mono text-[18px] text-[var(--color-text)] mt-2 font-500">24/5</p>
              </div>
              <div>
                <p class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Paires</p>
                <p class="font-mono text-[18px] text-[var(--color-text)] mt-2 font-500">EUR/USD</p>
              </div>
              <div>
                <p class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Type</p>
                <p class="font-mono text-[18px] text-[var(--color-text)] mt-2 font-500">Majors</p>
              </div>
            </div>
          </div>

          <!-- HUD corners -->
          <div class="absolute top-0 left-0 w-4 h-4 border-t border-l border-[var(--color-accent)] opacity-20"></div>
          <div class="absolute top-0 right-0 w-4 h-4 border-t border-r border-[var(--color-accent)] opacity-20"></div>
          <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l border-[var(--color-accent)] opacity-20"></div>
          <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-[var(--color-accent)] opacity-20"></div>
        </div>

        <!-- Right column — stacked cards -->
        <div class="flex flex-col gap-6">
          <!-- Matieres Premieres -->
          <div class="group relative border border-[var(--color-border)] p-[clamp(2rem,3vw,2.5rem)] flex-1 hover:border-[var(--color-accent)]/20 transition-all duration-500" data-reveal-right>
            <span class="font-mono text-[10px] tracking-[0.15em] uppercase text-[var(--color-accent)] block mb-4">Commodities</span>
            <h3 class="font-display text-[clamp(1.8rem,3vw,2.5rem)] font-300 tracking-[-0.02em] text-[var(--color-text)] mb-4 leading-[1.1]">
              Matieres Premieres
            </h3>
            <p class="text-[14px] font-300 text-[var(--color-text-muted)] leading-[1.7] mb-6">
              Or, petrole, metaux precieux. Des actifs tangibles, sensibles a la geopolitique.
            </p>
            <div class="grid grid-cols-2 gap-4 pt-4 border-t border-[var(--color-border)]">
              <div>
                <p class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Gold</p>
                <p class="font-mono text-[16px] text-green-400 mt-1">2,341.50</p>
              </div>
              <div>
                <p class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">WTI Crude</p>
                <p class="font-mono text-[16px] text-red-400 mt-1">78.42</p>
              </div>
            </div>
          </div>

          <!-- Risk Management mini card -->
          <div class="glass p-[clamp(1.5rem,2.5vw,2rem)]" data-reveal-right>
            <div class="flex items-center gap-3 mb-3">
              <div class="w-2 h-2 rounded-full bg-[var(--color-accent)] animate-pulse"></div>
              <span class="font-mono text-[10px] tracking-[0.15em] uppercase text-[var(--color-accent)]">Risk Management</span>
            </div>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <p class="font-mono text-[20px] text-[var(--color-text)] font-500">1-2%</p>
                <p class="font-mono text-[8px] tracking-[0.1em] uppercase text-[var(--color-text-subtle)] mt-1">Risque/trade</p>
              </div>
              <div>
                <p class="font-mono text-[20px] text-[var(--color-text)] font-500">1:2</p>
                <p class="font-mono text-[8px] tracking-[0.1em] uppercase text-[var(--color-text-subtle)] mt-1">R:R minimum</p>
              </div>
              <div>
                <p class="font-mono text-[20px] text-green-400 font-500">SL</p>
                <p class="font-mono text-[8px] tracking-[0.1em] uppercase text-[var(--color-text-subtle)] mt-1">Systematique</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       MARQUEE
  ══════════════════════════════════════════════ -->
  <Marquee items={["Forex", "Matieres Premieres", "Analyse Technique", "Gestion du Risque", "Trading Institutionnel", "Or & Petrole"]} />

  <!-- ══════════════════════════════════════════════
       02 — APPROCHE — HUD panels
  ══════════════════════════════════════════════ -->
  <section class="py-[clamp(5rem,12vh,10rem)]">
    <div class="px-[clamp(24px,5vw,80px)]">
      <div class="flex items-center gap-4 mb-12" data-reveal>
        <span class="section-num">02</span>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
        <span class="font-mono text-[11px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Notre approche</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-12 items-start">
        <!-- Left — statement -->
        <div data-reveal-left>
          <h2 class="font-display text-[clamp(2.5rem,5vw,4.5rem)] font-300 tracking-[-0.03em] text-[var(--color-text)] leading-[1.05] mb-8">
            Pas de raccourcis.<br />
            <span class="italic text-[var(--color-text-muted)]">Que de la methode.</span>
          </h2>

          <p class="text-[15px] font-300 text-[var(--color-text-muted)] leading-[1.7] max-w-lg mb-10">
            Nous ne vendons pas de signaux, pas de formations miracles. Notre approche est simple : un plan de trading rigoureux, une gestion du risque stricte, et la patience de laisser le marche venir a nous.
          </p>

          <!-- Quote -->
          <div class="border-l-2 border-[var(--color-accent)] pl-6 py-2">
            <p class="font-display text-[clamp(1.2rem,2vw,1.5rem)] font-300 italic text-[var(--color-text)] leading-[1.4]">
              "Le marche recompense la discipline, pas l'emotion."
            </p>
            <p class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-text-subtle)] mt-3">Brahim Djelloul</p>
          </div>
        </div>

        <!-- Right — Bento approach cards -->
        <div class="space-y-4" data-reveal-stagger>
          <div class="relative border border-[var(--color-border)] p-6 hover:border-[var(--color-accent)]/20 transition-all duration-500">
            <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-[var(--color-accent)] opacity-20"></div>
            <span class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-accent)] block mb-3">01 — Rigueur</span>
            <p class="text-[14px] font-300 text-[var(--color-text-muted)] leading-[1.7]">
              Chaque position est calculee. Le plan de trading est respecte sans exception. L'emotion n'a pas sa place.
            </p>
          </div>

          <div class="relative border border-[var(--color-border)] p-6 hover:border-[var(--color-accent)]/20 transition-all duration-500">
            <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-[var(--color-accent)] opacity-20"></div>
            <span class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-accent)] block mb-3">02 — Transparence</span>
            <p class="text-[14px] font-300 text-[var(--color-text-muted)] leading-[1.7]">
              Aucune promesse de gains. Les resultats sont documentes, verifiables. La realite du trading, sans filtre.
            </p>
          </div>

          <div class="relative border border-[var(--color-border)] p-6 hover:border-[var(--color-accent)]/20 transition-all duration-500">
            <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-[var(--color-accent)] opacity-20"></div>
            <span class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-accent)] block mb-3">03 — Accessibilite</span>
            <p class="text-[14px] font-300 text-[var(--color-text-muted)] leading-[1.7]">
              Rendre le trading comprehensible. Des articles, des analyses, un parcours documente pour apprendre serieusement.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       03 — BLOG PREVIEW — Webedia-style grid
  ══════════════════════════════════════════════ -->
  <section class="py-[clamp(5rem,12vh,10rem)] border-t border-[var(--color-border)]">
    <div class="px-[clamp(24px,5vw,80px)]">
      <div class="flex items-center justify-between mb-12" data-reveal>
        <div class="flex items-center gap-4">
          <span class="section-num">03</span>
          <span class="font-mono text-[11px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)]">Dernieres analyses</span>
        </div>
        <a href="/blog" class="group inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)] hover:text-[var(--color-text)] transition-colors duration-300">
          Tous les articles
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform duration-300 group-hover:translate-x-1">
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Webedia-style: 1 featured + 2 smaller -->
      <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_0.7fr] gap-6" data-reveal-stagger>
        <!-- Featured article -->
        <a href="/blog/comprendre-le-forex" class="group relative border border-[var(--color-border)] overflow-hidden hover:border-[var(--color-accent)]/20 transition-all duration-500">
          <!-- Chart decoration -->
          <div class="absolute inset-0 opacity-[0.03]">
            <svg viewBox="0 0 400 200" fill="none" class="w-full h-full">
              <path d="M0 180 Q100 120, 200 140 T400 60" stroke="#22c55e" stroke-width="1"/>
            </svg>
          </div>
          <div class="relative p-[clamp(2rem,3vw,3rem)]">
            <div class="flex items-center gap-3 mb-6">
              <span class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-accent)] bg-[var(--color-accent)]/10 px-2 py-1">Forex</span>
              <span class="font-mono text-[9px] tracking-[0.1em] text-[var(--color-text-subtle)]">20/04/2026</span>
            </div>
            <h3 class="font-display text-[clamp(1.5rem,3vw,2.5rem)] font-300 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-300 leading-[1.2] mb-4">
              Comprendre le Forex : les bases pour debuter
            </h3>
            <p class="text-[14px] font-300 text-[var(--color-text-muted)] leading-[1.7] mb-8 max-w-lg">
              Le marche des changes est le plus grand marche financier au monde. Decouvrez ses fondamentaux et pourquoi il attire autant de traders.
            </p>
            <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-[var(--color-accent)] group-hover:underline">
              Lire l'article →
            </span>
          </div>
        </a>

        <!-- 2 smaller articles stacked -->
        <div class="flex flex-col gap-6">
          <a href="/blog/matieres-premieres-opportunites" class="group border border-[var(--color-border)] p-6 flex-1 hover:border-[var(--color-accent)]/20 transition-all duration-500">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-accent)] bg-[var(--color-accent)]/10 px-2 py-1">Commodites</span>
              <span class="font-mono text-[9px] tracking-[0.1em] text-[var(--color-text-subtle)]">15/04/2026</span>
            </div>
            <h3 class="font-display text-[clamp(1.2rem,2vw,1.5rem)] font-300 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-300 leading-[1.3] mb-3">
              Matieres premieres : pourquoi elles meritent votre attention
            </h3>
            <span class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)] group-hover:text-[var(--color-accent)] transition-colors duration-300">
              Lire →
            </span>
          </a>

          <a href="/blog/gestion-du-risque" class="group border border-[var(--color-border)] p-6 flex-1 hover:border-[var(--color-accent)]/20 transition-all duration-500">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-accent)] bg-[var(--color-accent)]/10 px-2 py-1">Education</span>
              <span class="font-mono text-[9px] tracking-[0.1em] text-[var(--color-text-subtle)]">10/04/2026</span>
            </div>
            <h3 class="font-display text-[clamp(1.2rem,2vw,1.5rem)] font-300 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-300 leading-[1.3] mb-3">
              La gestion du risque : le pilier du trading rentable
            </h3>
            <span class="font-mono text-[9px] tracking-[0.12em] uppercase text-[var(--color-text-subtle)] group-hover:text-[var(--color-accent)] transition-colors duration-300">
              Lire →
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CTA — With trading visual
  ══════════════════════════════════════════════ -->
  <section class="py-[clamp(5rem,12vh,10rem)] border-t border-[var(--color-border)] relative overflow-hidden">
    <!-- Subtle chart in background -->
    <div class="absolute inset-0 opacity-[0.02]">
      <svg viewBox="0 0 800 200" fill="none" class="w-full h-full">
        <path d="M0 180 Q200 100, 400 120 T800 40" stroke="#3b82f6" stroke-width="2"/>
      </svg>
    </div>

    <div class="relative px-[clamp(24px,5vw,80px)]">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 items-end" data-reveal>
        <div>
          <span class="font-mono text-[10px] tracking-[0.15em] uppercase text-[var(--color-accent)] block mb-4">Rejoignez-nous</span>
          <h2 class="font-display text-[clamp(2rem,5vw,4rem)] font-300 tracking-[-0.03em] text-[var(--color-text)] leading-[1.1]">
            Suivez notre parcours<br/>
            <span class="italic text-[var(--color-text-muted)]">sur les marches.</span>
          </h2>
        </div>

        <div class="flex gap-4">
          <a href="/blog" class="group inline-flex items-center gap-3 border border-[var(--color-border)] px-6 py-3 text-[11px] tracking-[0.12em] uppercase text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 transition-all duration-400">
            Blog
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform duration-400 group-hover:translate-x-1"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
          <a href="/contact" class="group inline-flex items-center gap-3 border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/5 px-6 py-3 text-[11px] tracking-[0.12em] uppercase text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 hover:border-[var(--color-accent)]/50 transition-all duration-400">
            Contact
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform duration-400 group-hover:translate-x-1"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
