---
/**
 * Animated trading chart — candlestick + line overlay
 * Pure CSS animations, no JS dependency
 */
---

<div class="trading-chart" aria-hidden="true">
  <svg viewBox="0 0 800 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
    <!-- Grid lines -->
    <g class="chart-grid" opacity="0.06">
      <line x1="0" y1="80" x2="800" y2="80" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="0" y1="160" x2="800" y2="160" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="0" y1="240" x2="800" y2="240" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="0" y1="320" x2="800" y2="320" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="100" y1="0" x2="100" y2="400" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="200" y1="0" x2="200" y2="400" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="300" y1="0" x2="300" y2="400" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="400" y1="0" x2="400" y2="400" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="500" y1="0" x2="500" y2="400" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="600" y1="0" x2="600" y2="400" stroke="#fff" stroke-dasharray="4 8"/>
      <line x1="700" y1="0" x2="700" y2="400" stroke="#fff" stroke-dasharray="4 8"/>
    </g>

    <!-- Price labels -->
    <g class="chart-labels" opacity="0.15">
      <text x="770" y="84" fill="#fff" font-family="JetBrains Mono, monospace" font-size="9">1.0920</text>
      <text x="770" y="164" fill="#fff" font-family="JetBrains Mono, monospace" font-size="9">1.0880</text>
      <text x="770" y="244" fill="#fff" font-family="JetBrains Mono, monospace" font-size="9">1.0840</text>
      <text x="770" y="324" fill="#fff" font-family="JetBrains Mono, monospace" font-size="9">1.0800</text>
    </g>

    <!-- Candlesticks -->
    <g class="candlesticks">
      <!-- Green candles (bullish) -->
      <g class="candle candle-bull" style="--delay: 0.1s">
        <line x1="60" y1="280" x2="60" y2="180" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="52" y="220" width="16" height="40" fill="#22c55e" rx="1"/>
      </g>
      <g class="candle candle-bear" style="--delay: 0.2s">
        <line x1="110" y1="260" x2="110" y2="170" stroke="#ef4444" stroke-width="1" opacity="0.6"/>
        <rect x="102" y="190" width="16" height="50" fill="#ef4444" rx="1"/>
      </g>
      <g class="candle candle-bear" style="--delay: 0.3s">
        <line x1="160" y1="290" x2="160" y2="200" stroke="#ef4444" stroke-width="1" opacity="0.6"/>
        <rect x="152" y="220" width="16" height="45" fill="#ef4444" rx="1"/>
      </g>
      <g class="candle candle-bull" style="--delay: 0.4s">
        <line x1="210" y1="300" x2="210" y2="190" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="202" y="230" width="16" height="50" fill="#22c55e" rx="1"/>
      </g>
      <g class="candle candle-bull" style="--delay: 0.5s">
        <line x1="260" y1="260" x2="260" y2="160" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="252" y="190" width="16" height="50" fill="#22c55e" rx="1"/>
      </g>
      <g class="candle candle-bull" style="--delay: 0.6s">
        <line x1="310" y1="230" x2="310" y2="120" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="302" y="150" width="16" height="60" fill="#22c55e" rx="1"/>
      </g>
      <g class="candle candle-bear" style="--delay: 0.7s">
        <line x1="360" y1="200" x2="360" y2="100" stroke="#ef4444" stroke-width="1" opacity="0.6"/>
        <rect x="352" y="120" width="16" height="55" fill="#ef4444" rx="1"/>
      </g>
      <g class="candle candle-bull" style="--delay: 0.8s">
        <line x1="410" y1="190" x2="410" y2="90" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="402" y="120" width="16" height="45" fill="#22c55e" rx="1"/>
      </g>
      <g class="candle candle-bear" style="--delay: 0.9s">
        <line x1="460" y1="180" x2="460" y2="100" stroke="#ef4444" stroke-width="1" opacity="0.6"/>
        <rect x="452" y="110" width="16" height="50" fill="#ef4444" rx="1"/>
      </g>
      <g class="candle candle-bull" style="--delay: 1s">
        <line x1="510" y1="170" x2="510" y2="80" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="502" y="100" width="16" height="50" fill="#22c55e" rx="1"/>
      </g>
      <g class="candle candle-bear" style="--delay: 1.1s">
        <line x1="560" y1="150" x2="560" y2="60" stroke="#ef4444" stroke-width="1" opacity="0.6"/>
        <rect x="552" y="80" width="16" height="45" fill="#ef4444" rx="1"/>
      </g>
      <g class="candle candle-bull" style="--delay: 1.2s">
        <line x1="610" y1="140" x2="610" y2="50" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="602" y="70" width="16" height="50" fill="#22c55e" rx="1"/>
      </g>
      <g class="candle candle-bull" style="--delay: 1.3s">
        <line x1="660" y1="120" x2="660" y2="40" stroke="#22c55e" stroke-width="1" opacity="0.6"/>
        <rect x="652" y="55" width="16" height="45" fill="#22c55e" rx="1"/>
      </g>
    </g>

    <!-- Moving average line -->
    <path
      class="chart-line"
      d="M 40 250 Q 80 240, 120 230 T 200 250 T 280 200 T 360 160 T 440 140 T 520 120 T 600 90 T 680 70"
      stroke="#3b82f6"
      stroke-width="2"
      fill="none"
      opacity="0.7"
    />

    <!-- Line glow -->
    <path
      class="chart-line-glow"
      d="M 40 250 Q 80 240, 120 230 T 200 250 T 280 200 T 360 160 T 440 140 T 520 120 T 600 90 T 680 70"
      stroke="#3b82f6"
      stroke-width="6"
      fill="none"
      opacity="0.15"
      filter="blur(4px)"
    />

    <!-- Current price indicator -->
    <g class="price-indicator">
      <line x1="660" y1="70" x2="800" y2="70" stroke="#3b82f6" stroke-width="1" stroke-dasharray="3 3" opacity="0.5"/>
      <rect x="720" y="60" width="70" height="20" rx="2" fill="#3b82f6" opacity="0.9"/>
      <text x="755" y="74" fill="#fff" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="middle">1.0912</text>
    </g>

    <!-- Volume bars at bottom -->
    <g class="volume-bars" opacity="0.15">
      <rect x="52" y="370" width="16" height="20" fill="#22c55e"/>
      <rect x="102" y="360" width="16" height="30" fill="#ef4444"/>
      <rect x="152" y="365" width="16" height="25" fill="#ef4444"/>
      <rect x="202" y="355" width="16" height="35" fill="#22c55e"/>
      <rect x="252" y="350" width="16" height="40" fill="#22c55e"/>
      <rect x="302" y="340" width="16" height="50" fill="#22c55e"/>
      <rect x="352" y="360" width="16" height="30" fill="#ef4444"/>
      <rect x="402" y="345" width="16" height="45" fill="#22c55e"/>
      <rect x="452" y="365" width="16" height="25" fill="#ef4444"/>
      <rect x="502" y="350" width="16" height="40" fill="#22c55e"/>
      <rect x="552" y="362" width="16" height="28" fill="#ef4444"/>
      <rect x="602" y="345" width="16" height="45" fill="#22c55e"/>
      <rect x="652" y="338" width="16" height="52" fill="#22c55e"/>
    </g>
  </svg>

  <!-- HUD corners -->
  <div class="hud-corner hud-tl"></div>
  <div class="hud-corner hud-tr"></div>
  <div class="hud-corner hud-bl"></div>
  <div class="hud-corner hud-br"></div>

  <!-- HUD labels -->
  <div class="absolute top-4 left-4 font-mono text-[9px] tracking-[0.15em] uppercase text-[var(--color-accent)] opacity-60">
    EUR/USD &middot; 1H
  </div>
  <div class="absolute top-4 right-4 font-mono text-[9px] tracking-[0.15em] uppercase text-green-400 opacity-60">
    +0.34%
  </div>
</div>

<style>
  .trading-chart {
    position: relative;
    width: 100%;
    aspect-ratio: 2/1;
    border: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(59,130,246,0.03) 0%, transparent 50%);
    overflow: hidden;
  }

  .hud-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-color: var(--color-accent);
    opacity: 0.3;
  }
  .hud-tl { top: 0; left: 0; border-top: 1px solid; border-left: 1px solid; }
  .hud-tr { top: 0; right: 0; border-top: 1px solid; border-right: 1px solid; }
  .hud-bl { bottom: 0; left: 0; border-bottom: 1px solid; border-left: 1px solid; }
  .hud-br { bottom: 0; right: 0; border-bottom: 1px solid; border-right: 1px solid; }

  /* Candle appear animation */
  .candle {
    opacity: 0;
    transform: translateY(10px);
    animation: candleAppear 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay);
  }

  @keyframes candleAppear {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Line draw animation */
  .chart-line {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: drawLine 2.5s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }
  .chart-line-glow {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: drawLine 2.5s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  /* Price indicator pulse */
  .price-indicator {
    animation: pricePulse 2s ease-in-out infinite;
  }

  @keyframes pricePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  @media (prefers-reduced-motion: reduce) {
    .candle { opacity: 1; transform: none; animation: none; }
    .chart-line, .chart-line-glow { stroke-dashoffset: 0; animation: none; }
    .price-indicator { animation: none; }
  }
</style>
