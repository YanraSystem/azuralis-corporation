---
/**
 * TradingView Advanced Chart — EUR/USD live data
 */
---

<div class="tv-chart-wrapper">
  <!-- HUD labels -->
  <div class="tv-hud-tl">EUR/USD &middot; H1</div>
  <div class="tv-hud-tr">
    <span class="tv-live-dot"></span>LIVE
  </div>

  <!-- Chart container -->
  <div id="tv_eurusd_chart" class="tv-chart-inner"></div>

  <!-- HUD corners -->
  <div class="hud-c hud-tl"></div>
  <div class="hud-c hud-tr"></div>
  <div class="hud-c hud-bl"></div>
  <div class="hud-c hud-br"></div>
</div>

<script is:inline>
(function () {
  var s = document.createElement('script');
  s.src = 'https://s3.tradingview.com/tv.js';
  s.onload = function () {
    new TradingView.widget({
      width: '100%',
      height: 420,
      symbol: 'OANDA:EURUSD',
      interval: '60',
      timezone: 'Europe/Paris',
      theme: 'dark',
      style: '1',
      locale: 'fr',
      toolbar_bg: '#0a0a0a',
      enable_publishing: false,
      hide_top_toolbar: false,
      hide_legend: false,
      save_image: false,
      hide_volume: false,
      container_id: 'tv_eurusd_chart',
    });
  };
  document.head.appendChild(s);
})();
</script>

<style>
  .tv-chart-wrapper {
    position: relative;
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0a0a0a;
    overflow: hidden;
  }

  .tv-chart-inner {
    width: 100%;
  }

  .tv-hud-tl,
  .tv-hud-tr {
    position: absolute;
    top: 10px;
    z-index: 10;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    pointer-events: none;
  }

  .tv-hud-tl {
    left: 12px;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .tv-hud-tr {
    right: 12px;
    color: #22c55e;
    opacity: 0.8;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .tv-live-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    animation: livePulse 1.5s ease-in-out infinite;
  }

  @keyframes livePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hud-c {
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: var(--color-accent);
    opacity: 0.25;
  }
  .hud-tl { top: 0; left: 0; border-top: 1px solid; border-left: 1px solid; }
  .hud-tr { top: 0; right: 0; border-top: 1px solid; border-right: 1px solid; }
  .hud-bl { bottom: 0; left: 0; border-bottom: 1px solid; border-left: 1px solid; }
  .hud-br { bottom: 0; right: 0; border-bottom: 1px solid; border-right: 1px solid; }
</style>
