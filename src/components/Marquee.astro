---
interface Props {
  items: string[]
}
const { items } = Astro.props
const repeated = [...items, ...items]
---

<div class="overflow-hidden border-y border-[var(--color-border)] py-5">
  <div class="marquee-track">
    {repeated.map(item => (
      <span class="flex items-center gap-8 px-8">
        <span class="font-display text-[clamp(1.5rem,3vw,2.5rem)] font-300 lowercase tracking-[-0.02em] text-[var(--color-text-muted)] whitespace-nowrap">
          {item}
        </span>
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] shrink-0"></span>
      </span>
    ))}
  </div>
</div>
